# SQLite local (mặc định). Đổi sang Prisma Postgres:
# 1. Tạo DB tại https://console.prisma.io
# 2. Đổi provider trong prisma/schema.prisma thành "postgresql"
# 3. Dán connection string:
# DATABASE_URL="postgresql://user:pass@host/db?sslmode=require"
DATABASE_URL="file:./worlds/game.db"
AUTH_SECRET="theminecraft-game-secret-v1"
