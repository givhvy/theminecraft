{
  "name": "theminecraft",
  "version": "3.0.0",
  "description": "Minecraft clone full stack: Three.js + TypeScript client, authoritative Node.js server",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k \"cross-env PORT=3001 tsx watch server/index.ts\" \"vite\"",
    "build": "vite build",
    "start": "cross-env NODE_ENV=production tsx server/index.ts",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "db:push": "prisma db push",
    "db:generate": "prisma generate",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@prisma/client": "^6.19.3",
    "express": "^4.19.2",
    "prisma": "^6.19.3",
    "three": "^0.160.1",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.0",
    "@types/three": "^0.160.0",
    "@types/ws": "^8.5.10",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "tsx": "^4.16.0",
    "typescript": "^5.5.0",
    "vite": "^5.3.0",
    "vitest": "^1.6.0"
  }
}
